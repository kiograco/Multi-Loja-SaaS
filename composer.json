{
    "name": "orderhub/orderhub",
    "description": "OrderHub — SaaS multi-tenant de gestão de pedidos (Hexagonal + Event Sourcing + CQRS)",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.3",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-redis": "*",
        "firebase/php-jwt": "^7.1",
        "symfony/console": "^7.1",
        "ramsey/uuid": "^4.7",
        "twig/twig": "^3.11"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.3",
        "phpstan/phpstan": "^1.12",
        "friendsofphp/php-cs-fixer": "^3.64"
    },
    "autoload": {
        "psr-4": {
            "OrderHub\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OrderHub\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=unit",
        "test:integration": "phpunit --testsuite=integration",
        "stan": "phpstan analyse --memory-limit=512M",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "8.3.0"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
