{% extends 'layout.html.twig' %}
{% block title %}{{ product ? 'Editar produto' : 'Novo produto' }} — OrderHub{% endblock %}
{% block content %}
    <h1>{{ product ? 'Editar produto' : 'Novo produto' }}</h1>

    {% if errors|length > 0 %}
        <div class="flash flash-error" role="alert">
            <ul>
                {% for error in errors %}<li>{{ error }}</li>{% endfor %}
            </ul>
        </div>
    {% endif %}

    <form method="post" action="{{ product ? '/app/products/' ~ product.id ~ '/edit' : '/app/products/new' }}" class="form">
        <label for="name">Nome</label>
        <input type="text" id="name" name="name" value="{{ product ? product.name : '' }}" required>

        <label for="price">Preço (R$)</label>
        <input type="text" id="price" name="price" inputmode="decimal" value="{{ product ? product.price : '' }}" required>

        <label for="stockQuantity">Estoque</label>
        <input type="number" id="stockQuantity" name="stockQuantity" min="0" step="1" value="{{ product ? product.stockQuantity : 0 }}" required>

        <button type="submit">Salvar</button>
    </form>
{% endblock %}
