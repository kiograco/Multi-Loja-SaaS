<nav class="app-nav" aria-label="Navegação principal">
    <a href="/app/dashboard" class="app-nav__brand">OrderHub</a>

    {% if stores is defined and stores|length > 1 %}
        <details class="store-switcher">
            <summary>
                {% for store in stores %}{% if store.id == activeTenantId %}{{ store.storeName }}{% endif %}{% endfor %}
            </summary>
            <div class="store-switcher__list">
                {% for store in stores %}
                    {% if store.id != activeTenantId %}
                        <form method="post" action="/app/switch-tenant/{{ store.id }}">
                            <button type="submit" class="store-switcher__item">{{ store.storeName }}</button>
                        </form>
                    {% endif %}
                {% endfor %}
            </div>
        </details>
    {% endif %}

    <a href="/app/dashboard" class="app-nav__link" data-nav-path="/app/dashboard">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
            <rect x="3" y="3" width="7" height="9" rx="1.5"/>
            <rect x="14" y="3" width="7" height="5" rx="1.5"/>
            <rect x="14" y="12" width="7" height="9" rx="1.5"/>
            <rect x="3" y="16" width="7" height="5" rx="1.5"/>
        </svg>
        <span>Dashboard</span>
    </a>

    <a href="/app/products" class="app-nav__link" data-nav-path="/app/products">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
            <path d="M3 7.5 12 3l9 4.5v9L12 21l-9-4.5v-9Z"/>
            <path d="M3 7.5 12 12l9-4.5"/>
            <path d="M12 12v9"/>
        </svg>
        <span>Produtos</span>
    </a>

    <a href="/app/orders" class="app-nav__link" data-nav-path="/app/orders">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
            <path d="M6 3h9l3 3v15H6z"/>
            <path d="M9 9h6M9 13h6M9 17h4"/>
        </svg>
        <span>Pedidos</span>
    </a>

    <a href="/app/settings" class="app-nav__link" data-nav-path="/app/settings">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
            <circle cx="12" cy="12" r="3"/>
            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1Z"/>
        </svg>
        <span>Configurações</span>
    </a>

    <div class="app-nav__logout">
        <form method="post" action="/app/logout">
            <button type="submit">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                    <path d="M16 17l5-5-5-5"/>
                    <path d="M21 12H9"/>
                </svg>
                <span>Sair</span>
            </button>
        </form>
    </div>
</nav>
