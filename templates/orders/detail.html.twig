{% extends 'layout.html.twig' %}
{% block title %}Pedido de {{ order.customerName }} — OrderHub{% endblock %}
{% block content %}
    <p><a href="/app/orders">&larr; Voltar para pedidos</a></p>
    <h1>Pedido de {{ order.customerName }}</h1>
    <p>{{ order.customerEmail }}</p>

    {% include 'orders/_status_panel.html.twig' %}

    <h2>Itens</h2>
    <table>
        <thead>
        <tr>
            <th scope="col">Produto</th>
            <th scope="col">Quantidade</th>
            <th scope="col">Preço unitário</th>
        </tr>
        </thead>
        <tbody>
        {% for item in order.items %}
            <tr>
                <td>{{ item.productName }}</td>
                <td>{{ item.quantity }}</td>
                <td>{{ item.currency }} {{ (item.unitPriceCents / 100)|number_format(2, ',', '.') }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <h2>Timeline de eventos</h2>
    <p>Histórico imutável, lido diretamente do event store — a mesma sequência que reconstrói o estado do pedido.</p>
    {% include 'orders/_event_timeline.html.twig' %}
{% endblock %}
