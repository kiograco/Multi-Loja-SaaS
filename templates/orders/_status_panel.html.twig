<div id="order-status-panel">
    <p>Status atual: <span class="badge badge-{{ order.status }}">{{ order.status }}</span></p>
    {% if order.trackingCode %}<p>Código de rastreio: {{ order.trackingCode }}</p>{% endif %}

    <div class="order-actions">
        {% if order.status == 'criado' %}
            <form method="post" action="/app/orders/{{ order.orderId }}/pay"
                  hx-post="/app/orders/{{ order.orderId }}/pay"
                  hx-target="#order-status-panel"
                  hx-swap="outerHTML"
                  hx-confirm="Confirmar pagamento deste pedido?">
                <button type="submit">Marcar como pago</button>
            </form>
        {% elseif order.status == 'pago' %}
            <form method="post" action="/app/orders/{{ order.orderId }}/ship"
                  hx-post="/app/orders/{{ order.orderId }}/ship"
                  hx-target="#order-status-panel"
                  hx-swap="outerHTML"
                  hx-confirm="Confirmar envio deste pedido?">
                <label for="trackingCode" class="sr-only">Código de rastreio</label>
                <input type="text" id="trackingCode" name="trackingCode" placeholder="Código de rastreio" required>
                <button type="submit">Marcar como enviado</button>
            </form>
        {% elseif order.status == 'enviado' %}
            <form method="post" action="/app/orders/{{ order.orderId }}/deliver"
                  hx-post="/app/orders/{{ order.orderId }}/deliver"
                  hx-target="#order-status-panel"
                  hx-swap="outerHTML"
                  hx-confirm="Confirmar entrega deste pedido?">
                <button type="submit">Marcar como entregue</button>
            </form>
        {% endif %}

        {% if order.status in ['criado', 'pago'] %}
            <form method="post" action="/app/orders/{{ order.orderId }}/cancel"
                  hx-post="/app/orders/{{ order.orderId }}/cancel"
                  hx-target="#order-status-panel"
                  hx-swap="outerHTML"
                  hx-confirm="{{ order.status == 'pago' ? 'Cancelar este pedido pago vai exigir estorno manual ao cliente. Confirmar cancelamento?' : 'Confirmar cancelamento deste pedido?' }}">
                <button type="submit" class="button--danger">Cancelar pedido</button>
            </form>
        {% endif %}

        {% if order.status in ['pago', 'enviado', 'entregue'] %}
            <a href="/app/orders/{{ order.orderId }}/invoice" class="button button--secondary">Baixar nota fiscal</a>
        {% endif %}
    </div>
</div>
