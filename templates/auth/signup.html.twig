{% extends 'layout.html.twig' %}
{% block title %}Criar conta — OrderHub{% endblock %}
{% block content %}
    <h1>Criar conta</h1>

    {% if errors|length > 0 %}
        <div class="flash flash-error" role="alert">
            <ul>
                {% for error in errors %}<li>{{ error }}</li>{% endfor %}
            </ul>
        </div>
    {% endif %}

    <form method="post" action="/app/signup" class="form">
        <label for="storeName">Nome da loja</label>
        <input type="text" id="storeName" name="storeName" value="{{ storeName }}" required autofocus>

        <label for="email">E-mail</label>
        <input type="email" id="email" name="email" value="{{ email }}" autocomplete="username" required>

        <label for="password">Senha</label>
        <input type="password" id="password" name="password" autocomplete="new-password" minlength="8" required>
        <p class="form-hint">Mínimo de 8 caracteres.</p>

        <button type="submit">Criar conta</button>
    </form>

    <p class="form-hint">Já tem uma conta? <a href="/app/login">Entrar</a></p>
{% endblock %}
